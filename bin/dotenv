#!/bin/bash

SCRIPT_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
DEFAULT_ENVIRONMENT_DIR=$(cd "$SCRIPT_DIR/.." && pwd)
export ENVIRONMENT_DIR="${ENVIRONMENT_DIR:-$DEFAULT_ENVIRONMENT_DIR}"

find_standalone_dotenv_cli() {
  local candidate
  local current_script

  current_script="$SCRIPT_DIR/dotenv"

  for candidate in \
    "${DOTENV_CLI_BIN:-}" \
    "$HOME/Source/dotenv-cli/bin/dotenv"
  do
    if [[ -n "$candidate" && -x "$candidate" ]]; then
      if [[ "$(cd "$(dirname "$candidate")" && pwd)/$(basename "$candidate")" != "$current_script" ]]; then
        echo "$candidate"
        return 0
      fi
    fi
  done

  return 1
}

standalone_cli=$(find_standalone_dotenv_cli)
if [[ -n "$standalone_cli" ]]; then
  exec "$standalone_cli" "$@"
fi

source "$ENVIRONMENT_DIR/src/dotenv-local.sh"
dotenv_dispatch_local "$@"
